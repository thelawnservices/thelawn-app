{
  "expo": {
    "name": "TheLawn",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpeg",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-logo.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.thelawnservices.mobile",
      "infoPlist": {
        "NSCalendarsUsageDescription": "TheLawn uses your calendar to add service appointments.",
        "NSRemindersUsageDescription": "TheLawn can add appointment reminders to your calendar.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "permissions": [
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.jpeg",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.jpeg"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.jpeg",
          "color": "#34FF7A",
          "sounds": []
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "TheLawn uses your calendar to save service appointments."
        }
      ],
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "4a03f4d7-dfad-4279-9c26-c8e766ff2711"
      }
    }
  }
}
